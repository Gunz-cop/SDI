# Core site settings
SBI_SITE_URL=https://example.com
SBI_DIST_DIR=dist

# Optional explicit paths
# SBI_STATE_PATH=.sbi/state.json
# SBI_MANIFEST_PATH=.sbi/manifest.json
# SBI_LOG_PATH=.sbi/submissions.json
# SBI_SITEMAP_PATH=dist/sitemap-0.xml

# Optional runtime toggles
# SBI_FORCE_SUBMIT=0
# SBI_DRY_RUN=0
# SBI_OPTIONAL_DESTINATIONS=google
# SBI_GOOGLE_MODE=optional
# SBI_INDEXNOW_MODE=required

# IndexNow
INDEXNOW_KEY=
# INDEXNOW_HOST=example.com
# INDEXNOW_KEY_LOCATION=https://example.com/your-key.txt

# Google Indexing API
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Alternative Google credential loading
# INDEXING_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"..."}
# GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
